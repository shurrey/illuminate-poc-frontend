# Cognito Configuration
# These values come from SSM parameters published by the illuminate-conversational-intelligence project:
#   /illuminate/dev/cognito-pool-id
#   /illuminate/dev/cognito-client-id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URLs (update to your CloudFront domain for production)
NEXT_PUBLIC_REDIRECT_SIGN_IN=http://localhost:3000/
NEXT_PUBLIC_REDIRECT_SIGN_OUT=http://localhost:3000/

# Agent API URL (Lambda Function URL from the illuminate-conversational-intelligence project)
# SSM: /illuminate/dev/api-url
NEXT_PUBLIC_AGENT_API_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws
